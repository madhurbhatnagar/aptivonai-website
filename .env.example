# Application
APP_NAME=Enterprise Knowledge Assistant
APP_ENV=development
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:8501

# Streamlit
STREAMLIT_SERVER_PORT=8501
BACKEND_API_URL=http://localhost:8000

# Storage
UPLOAD_DIR=./data/uploads
PROCESSED_DIR=./data/processed
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=enterprise_documents
ALLOWED_FILE_TYPES=pdf,docx,txt,csv,xlsx
MAX_UPLOAD_SIZE_MB=25

# Retrieval
RETRIEVAL_TOP_K=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# OpenAI-compatible LLM API.
# For minimum-cost local testing, install Ollama and use the defaults below.
LLM_PROVIDER=ollama
LLM_API_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.2:3b
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=700

# Embeddings.
# Local embeddings do not need an API key. We will use sentence-transformers in a later step.
EMBEDDING_PROVIDER=local
EMBEDDING_API_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=not-required-for-local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# Security placeholders for future SaaS hardening
SECRET_KEY=replace-with-a-secure-random-secret
ENABLE_AUTH=false
